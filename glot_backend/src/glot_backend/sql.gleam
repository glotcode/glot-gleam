  let sql =
    "SELECT day
FROM metrics_completed_day
ORDER BY day DESC
LIMIT 1"
  #(sql, [], get_max_completed_metrics_day_decoder())
}

pub fn get_max_completed_metrics_day_decoder() -> decode.Decoder(
  GetMaxCompletedMetricsDay,
) {
