  request_count,
  error_count,
  avg_duration_ns
)
SELECT
  $1::date AS day,
  'page',
  route,
  COUNT(*),
  COUNT(*) FILTER (WHERE status_code >= 400),
  COALESCE(AVG(duration_ns)::BIGINT, 0)
FROM page_log
WHERE DATE_TRUNC('day', created_at AT TIME ZONE 'UTC')::date = $1::date
GROUP BY route
ON CONFLICT (day, surface, name) DO NOTHING"
  #(sql, [dev.ParamDate(day)])
}

